<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Vehicle Insurance</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
    <nav class="bg-white shadow-sm border-b">
        <div class="container mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
                DriveGuard<span class="text-gray-900 font-light">Insurance</span>
            </a>
            <div class="space-x-4 sm:space-x-6 flex items-center">
                <a href="/" class="text-gray-600 hover:text-blue-600 font-medium transition-colors">Home</a>
                
                <% if (typeof customer !== 'undefined' && customer) { %>
                    <!-- User Dropdown (Hover Activated) -->
                    <div class="relative group">
                        <button class="flex items-center gap-2 focus:outline-none py-2">
                            <div class="w-9 h-9 bg-indigo-100 text-indigo-700 rounded-full flex items-center justify-center font-bold border border-indigo-200">
                                <%= customer.email.charAt(0).toUpperCase() %>
                            </div>
                            <span class="text-gray-700 font-medium hidden sm:block max-w-[100px] truncate"><%= customer.email.split('@')[0] %></span>
                            <i class="fas fa-chevron-down text-gray-400 text-xs mt-0.5 group-hover:text-indigo-600 transition-colors"></i>
                        </button>
                        
                        <!-- Dropdown Menu -->
                        <div class="absolute right-0 mt-0 w-48 bg-white rounded-xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 transform origin-top-right">
                            <div class="p-2 space-y-1">
                                <div class="px-3 py-2 border-b border-gray-100 mb-1">
                                    <p class="text-xs text-gray-400 uppercase font-bold tracking-wider">Signed in as</p>
                                    <p class="text-sm font-medium text-gray-900 truncate" title="<%= customer.email %>"><%= customer.email %></p>
                                </div>
                                <a href="/user/dashboard" class="block px-3 py-2 text-sm text-gray-700 font-medium hover:bg-indigo-50 hover:text-indigo-700 rounded-lg transition-colors">
                                    <i class="fas fa-table-columns w-5 text-center mr-1"></i> Dashboard
                                </a>
                                <div class="border-t border-gray-100 my-1"></div>
                                <form action="/api/user/logout" method="POST" class="w-full m-0">
                                    <button type="submit" class="w-full text-left px-3 py-2 text-sm text-red-600 font-medium hover:bg-red-50 rounded-lg transition-colors">
                                        <i class="fas fa-sign-out-alt w-5 text-center mr-1"></i> Logout
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <a href="/user/login" class="text-gray-600 hover:text-blue-600 font-medium transition-colors">Customer Login</a>
                    <a href="/admin/login" class="px-4 py-2 bg-slate-900 text-white rounded-lg hover:bg-slate-800 transition-all shadow-md hover:shadow-lg text-sm font-medium hidden sm:block">Admin</a>
                <% } %>
            </div>
        </div>
    </nav>
    <main class="flex-grow">
        <div class="container mx-auto px-4 py-8">
            <% if (messages && messages.success) { %>
                <div class="mb-6 p-4 bg-green-100 border-l-4 border-green-500 text-green-700 rounded shadow-sm">
                    <%= messages.success %>
                </div>
            <% } %>
            <% if (messages && messages.error) { %>
                <div class="mb-6 p-4 bg-red-100 border-l-4 border-red-500 text-red-700 rounded shadow-sm">
                    <%= messages.error %>
                </div>
            <% } %>
