<!-- Admin Sidebar Partial -->
<aside class="w-full md:w-64 bg-white rounded-3xl shadow-xl border border-gray-100 p-6 self-start">
    <div class="flex items-center gap-4 mb-10 pb-6 border-b border-gray-100">
        <div class="w-12 h-12 bg-gradient-to-br from-blue-100 to-indigo-100 rounded-2xl flex items-center justify-center shadow-inner">
            <i class="fas fa-user-shield text-blue-600 text-xl"></i>
        </div>
        <div class="overflow-hidden">
            <p class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest leading-tight">Administrator</p>
            <p class="font-bold text-gray-800 text-sm overflow-hidden text-ellipsis whitespace-nowrap" title="<%= user.email %>"><%= user.email %></p>
        </div>
    </div>

    <nav class="space-y-2.5">
        <a href="/admin/dashboard" class="group flex items-center gap-4 p-4 rounded-2xl transition-all font-bold <%= activeTab === 'dashboard' ? 'bg-blue-600 text-white shadow-lg shadow-blue-200' : 'text-gray-500 hover:bg-gray-50 hover:text-blue-600' %>">
            <div class="w-6 text-center">
                <i class="fas fa-chart-line <%= activeTab === 'dashboard' ? 'text-white' : 'text-gray-400 group-hover:text-blue-600' %>"></i>
            </div>
            <span>Dashboard</span>
        </a>

        <a href="/admin/brands" class="group flex items-center gap-4 p-4 rounded-2xl transition-all font-bold <%= activeTab === 'brands' ? 'bg-blue-600 text-white shadow-lg shadow-blue-200' : 'text-gray-500 hover:bg-gray-50 hover:text-blue-600' %>">
            <div class="w-6 text-center">
                <i class="fas fa-tags <%= activeTab === 'brands' ? 'text-white' : 'text-gray-400 group-hover:text-blue-600' %>"></i>
            </div>
            <span>Brands</span>
        </a>

        <a href="/admin/models" class="group flex items-center gap-4 p-4 rounded-2xl transition-all font-bold <%= activeTab === 'models' ? 'bg-blue-600 text-white shadow-lg shadow-blue-200' : 'text-gray-500 hover:bg-gray-50 hover:text-blue-600' %>">
            <div class="w-6 text-center">
                <i class="fas fa-car-side <%= activeTab === 'models' ? 'text-white' : 'text-gray-400 group-hover:text-blue-600' %>"></i>
            </div>
            <span>Models</span>
        </a>

        <a href="/admin/variants" class="group flex items-center gap-4 p-4 rounded-2xl transition-all font-bold <%= activeTab === 'variants' ? 'bg-blue-600 text-white shadow-lg shadow-blue-200' : 'text-gray-500 hover:bg-gray-50 hover:text-blue-600' %>">
            <div class="w-6 text-center">
                <i class="fas fa-cogs <%= activeTab === 'variants' ? 'text-white' : 'text-gray-400 group-hover:text-blue-600' %>"></i>
            </div>
            <span>Variants</span>
        </a>

        <a href="/admin/policies" class="group flex items-center gap-4 p-4 rounded-2xl transition-all font-bold <%= activeTab === 'policies' ? 'bg-blue-600 text-white shadow-lg shadow-blue-200' : 'text-gray-500 hover:bg-gray-50 hover:text-blue-600' %>">
            <div class="w-6 text-center">
                <i class="fas fa-file-invoice <%= activeTab === 'policies' ? 'text-white' : 'text-gray-400 group-hover:text-blue-600' %>"></i>
            </div>
            <span>Policies</span>
        </a>

        <a href="/admin/claims" class="group flex items-center gap-4 p-4 rounded-2xl transition-all font-bold <%= activeTab === 'claims' ? 'bg-blue-600 text-white shadow-lg shadow-blue-200' : 'text-gray-500 hover:bg-gray-50 hover:text-blue-600' %>">
            <div class="w-6 text-center">
                <i class="fas fa-clipboard-check <%= activeTab === 'claims' ? 'text-white' : 'text-gray-400 group-hover:text-blue-600' %>"></i>
            </div>
            <span>Claims Management</span>
        </a>
    </nav>
</aside>
