<%- include('partials/header') %>

<div class="flex min-h-screen bg-gray-50">
    <%- include('partials/user-sidebar', { activeTab: 'claims' }) %>

    <main class="flex-1 overflow-y-auto">
        <div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8">
            
            <div class="mb-8">
                <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Insurance Claims History</h1>
                <p class="text-gray-500 mt-1">Track the status of your reported accidents and damages.</p>
            </div>

            <!-- Dashboard Summary for Claims -->
            <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-8">
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Total Claims</p>
                    <p class="text-2xl font-black text-slate-900"><%= claims.length %></p>
                </div>
                <div class="bg-amber-50 p-6 rounded-2xl border border-amber-100 shadow-sm">
                    <p class="text-xs font-bold text-amber-600 uppercase tracking-widest mb-1">In Process</p>
                    <p class="text-2xl font-black text-amber-700"><%= claims.filter(c => ['submitted', 'under_review', 'docs_verified'].includes(c.status)).length %></p>
                </div>
                <div class="bg-emerald-50 p-6 rounded-2xl border border-emerald-100 shadow-sm">
                    <p class="text-xs font-bold text-emerald-600 uppercase tracking-widest mb-1">Approved</p>
                    <p class="text-2xl font-black text-emerald-700"><%= claims.filter(c => c.status === 'approved').length %></p>
                </div>
                <div class="bg-rose-50 p-6 rounded-2xl border border-rose-100 shadow-sm">
                    <p class="text-xs font-bold text-rose-600 uppercase tracking-widest mb-1">Rejected</p>
                    <p class="text-2xl font-black text-rose-700"><%= claims.filter(c => c.status === 'rejected').length %></p>
                </div>
            </div>

            <!-- Claims List -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold uppercase tracking-wider text-xs">
                            <tr>
                                <th class="px-6 py-4">Claim ID</th>
                                <th class="px-6 py-4">Policy Number</th>
                                <th class="px-6 py-4">Vehicle Details</th>
                                <th class="px-6 py-4">Reason</th>
                                <th class="px-6 py-4">Amount</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Progress Timeline</th>
                                <th class="px-6 py-4 text-right">Last Update</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 font-medium">
                            <% if (claims.length === 0) { %>
                                <tr>
                                    <td colspan="8" class="px-6 py-20 text-center">
                                        <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300 text-3xl">
                                            <i class="fas fa-clipboard-check"></i>
                                        </div>
                                        <h3 class="text-lg font-bold text-slate-900">No insurance claims yet</h3>
                                        <p class="text-slate-500">When you report an accident or damage, it will appear here.</p>
                                    </td>
                                </tr>
                            <% } else { %>
                                <% claims.forEach(claim => { %>
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="px-6 py-4">
                                            <span class="text-slate-900 font-bold">#CLM-<%= String(claim.id).padStart(5, '0') %></span>
                                        </td>
                                        <td class="px-6 py-4 font-bold text-blue-600"><%= claim.policy_number %></td>
                                        <td class="px-6 py-4 text-slate-900"><%= claim.vehicle_type === 'car' ? 'Car' : 'Bike' %> — <%= claim.manufacturing_year %></td>
                                        <td class="px-6 py-4">
                                            <span class="px-2 py-1 bg-slate-100 rounded text-[10px] font-bold text-slate-600 uppercase">
                                                <%= claim.claim_reason %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 font-bold text-slate-900">₹<%= parseFloat(claim.claim_amount).toLocaleString('en-IN') %></td>
                                        
                                        <!-- Status Badge -->
                                        <td class="px-6 py-4">
                                            <% if (claim.status === 'rejected') { %>
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-black bg-rose-100 text-rose-700 uppercase">Rejected</span>
                                            <% } else if (claim.status === 'paid') { %>
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-black bg-indigo-100 text-indigo-700 uppercase">Settled ✔</span>
                                            <% } else { %>
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-black bg-blue-100 text-blue-700 uppercase"><%= claim.status.replace('_', ' ') %></span>
                                            <% } %>
                                        </td>

                                        <!-- Timeline Progress -->
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-1">
                                                <% for(let i=1; i<=5; i++) { %>
                                                    <div class="w-6 h-1.5 rounded-full <%= (claim.current_stage >= i && claim.status !== 'rejected') ? 'bg-emerald-500 shadow-sm' : 'bg-slate-200' %>"></div>
                                                <% } %>
                                                <span class="text-[10px] font-bold ml-1 <%= claim.status === 'rejected' ? 'text-rose-500' : 'text-slate-400' %>">
                                                    <%= claim.status === 'rejected' ? 'Rejected' : `Step ${claim.current_stage}/5` %>
                                                </span>
                                            </div>
                                        </td>

                                        <!-- Date -->
                                        <td class="px-6 py-4 text-right text-slate-500 font-bold">
                                            <%= new Date(claim.created_at).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' }) %>
                                        </td>
                                    </tr>

                                    <!-- Expandable Details with Full Timeline -->
                                    <tr class="bg-slate-50/30 border-b border-slate-100">
                                        <td colspan="8" class="px-6 py-4">
                                            <div class="flex items-center justify-between">
                                                <!-- Steps Labels -->
                                                <div class="flex flex-1 justify-between max-w-2xl text-[9px] font-black text-slate-400 uppercase tracking-widest">
                                                    <div class="<%= claim.current_stage >= 1 ? 'text-blue-600' : '' %>">1. Submitted</div>
                                                    <i class="fas fa-chevron-right mt-0.5 text-slate-200"></i>
                                                    <div class="<%= claim.current_stage >= 2 ? 'text-blue-600' : '' %>">2. In Review</div>
                                                    <i class="fas fa-chevron-right mt-0.5 text-slate-200"></i>
                                                    <div class="<%= claim.current_stage >= 3 ? 'text-blue-600' : '' %>">3. Verified</div>
                                                    <i class="fas fa-chevron-right mt-0.5 text-slate-200"></i>
                                                    <div class="<%= claim.current_stage >= 4 ? 'text-blue-600' : '' %>">4. Approved</div>
                                                    <i class="fas fa-chevron-right mt-0.5 text-slate-200"></i>
                                                    <div class="<%= claim.status === 'paid' ? 'text-emerald-600' : '' %>">5. Paid</div>
                                                </div>

                                                <!-- Rejection / Payout Info -->
                                                <% if (claim.status === 'rejected') { %>
                                                    <div class="text-rose-600 text-[10px] font-bold bg-rose-50 px-3 py-1 rounded-lg border border-rose-100">
                                                        <i class="fas fa-info-circle mr-1"></i> Rejected: <%= claim.rejection_reason %>
                                                    </div>
                                                <% } else if (claim.payout_amount > 0) { %>
                                                    <div class="text-emerald-600 text-[10px] font-bold bg-emerald-50 px-3 py-1 rounded-lg border border-emerald-100 flex items-center gap-2">
                                                        <i class="fas fa-coins"></i>
                                                        Settlement: ₹<%= parseFloat(claim.payout_amount).toLocaleString('en-IN') %>
                                                        <span class="text-[9px] px-1.5 py-0.5 bg-emerald-600 text-white rounded"><%= claim.payout_status.toUpperCase() %></span>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
