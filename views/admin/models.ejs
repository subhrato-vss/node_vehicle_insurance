<%- include('../partials/admin-header') %>

<div class="flex flex-col md:flex-row gap-8 py-6">
    <!-- Sidebar -->
    <%- include('../partials/admin-sidebar', { activeTab: 'models' }) %>

    <!-- Main Content -->
    <main class="flex-grow space-y-8">
        <!-- Toast Container -->
        <div id="toastContainer" class="fixed top-5 right-5 z-[100] flex flex-col gap-3"></div>

        <!-- Add Model Section -->
        <div class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100">
            <h2 class="text-2xl font-extrabold text-gray-900 mb-6 flex items-center gap-3">
                <i class="fas fa-plus-circle text-indigo-600"></i> Add New Model
            </h2>
            <form id="addModelForm" class="grid grid-cols-1 md:grid-cols-4 gap-6 items-end">
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700">Vehicle Type</label>
                    <select id="addVehicleType" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                        <option value="">Any</option>
                        <option value="car">Car</option>
                        <option value="bike">Bike</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700">Select Brand</label>
                    <select name="brand_id" id="addBrandId" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required>
                        <option value="">Choose Brand</option>
                        <% brands.forEach(brand => { %>
                            <option value="<%= brand.id %>" data-type="<%= brand.type %>"><%= brand.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700">Model Name</label>
                    <input type="text" name="name" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. Swift, Pulsar" required>
                </div>
                <button type="submit" class="p-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 hover:shadow-lg transition-all uppercase tracking-wide">
                    Save Model
                </button>
            </form>
        </div>

        <!-- Models List -->
        <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="px-8 py-6 border-b flex flex-col xl:flex-row justify-between items-center gap-4">
                <h2 class="text-2xl font-extrabold text-gray-900 flex items-center gap-3">
                    <i class="fas fa-list text-purple-600"></i> Models List
                </h2>
                <div class="flex flex-col md:flex-row gap-4 w-full xl:w-auto">
                    <!-- Search Bar -->
                    <div class="relative w-full md:w-64">
                        <i class="fas fa-search absolute left-4 top-3.5 text-gray-400"></i>
                        <input type="text" id="modelSearchInput" placeholder="Search brand or model..." class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                    </div>
                    
                    <!-- Filter Buttons -->
                    <div class="flex bg-gray-100 p-1 rounded-xl w-full md:w-auto">
                        <button onclick="filterModels('all')" id="filter-all" class="filter-btn flex-1 md:flex-none px-4 py-2 rounded-lg font-bold transition-all <%= currentType === 'all' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                            All <span id="count-all" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-gray-200/50 text-gray-500"><%= typeof counts !== 'undefined' ? counts.all : 0 %></span>
                        </button>
                        <button onclick="filterModels('car')" id="filter-car" class="filter-btn flex-1 md:flex-none px-4 py-2 rounded-lg font-bold transition-all <%= currentType === 'car' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                            Cars <span id="count-car" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-600"><%= typeof counts !== 'undefined' ? counts.car : 0 %></span>
                        </button>
                        <button onclick="filterModels('bike')" id="filter-bike" class="filter-btn flex-1 md:flex-none px-4 py-2 rounded-lg font-bold transition-all <%= currentType === 'bike' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                            Bikes <span id="count-bike" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-indigo-100 text-indigo-600"><%= typeof counts !== 'undefined' ? counts.bike : 0 %></span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 text-gray-500 uppercase text-sm font-bold tracking-wider">
                        <tr>
                            <th class="px-8 py-5">ID</th>
                            <th class="px-8 py-5">Brand</th>
                            <th class="px-8 py-5">Model Name</th>
                            <th class="px-8 py-5">Vehicle Type</th>
                            <th class="px-8 py-5 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="modelTableBody" class="divide-y divide-gray-100">
                        <% if (models.length === 0) { %>
                            <tr><td colspan="5" class="px-8 py-10 text-center text-gray-500 italic">No models found. Add one above!</td></tr>
                        <% } %>
                        <% models.forEach(model => { %>
                            <tr class="hover:bg-blue-50/30 transition-colors">
                                <td class="px-8 py-5 font-mono text-gray-400">#<%= model.id %></td>
                                <td class="px-8 py-5 font-bold text-gray-800"><%= model.brand_name %></td>
                                <td class="px-8 py-5 font-bold text-blue-600"><%= model.name %></td>
                                <td class="px-8 py-5">
                                    <span class="px-3 py-1 rounded-full text-xs font-bold uppercase <%= model.brand_type === 'car' ? 'bg-blue-100 text-blue-700' : 'bg-indigo-100 text-indigo-700' %>">
                                        <%= model.brand_type %>
                                    </span>
                                </td>
                                <td class="px-8 py-5">
                                    <div class="flex justify-center gap-3">
                                        <button onclick="openEditModal(<%= JSON.stringify(model) %>)" class="p-2 text-blue-600 hover:bg-blue-100 rounded-lg transition-all" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button onclick="deleteModel(<%= model.id %>)" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-all" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<!-- Edit Modal -->
<div id="editModal" class="fixed inset-0 bg-black/50 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white p-8 rounded-3xl shadow-2xl w-full max-w-md transform transition-all scale-100">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-2xl font-extrabold text-gray-900">Edit Model</h3>
            <button onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        <form id="editModelForm" class="space-y-6">
            <input type="hidden" name="id" id="editModelId">
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">Vehicle Type</label>
                <select id="editVehicleType" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="">Any</option>
                    <option value="car">Car</option>
                    <option value="bike">Bike</option>
                </select>
            </div>
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">Select Brand</label>
                <select name="brand_id" id="editBrandId" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required>
                    <% brands.forEach(brand => { %>
                        <option value="<%= brand.id %>" data-type="<%= brand.type %>"><%= brand.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">Model Name</label>
                <input type="text" name="name" id="editName" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required>
            </div>
            <button type="submit" class="w-full p-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-all uppercase tracking-wide">
                Update Model
            </button>
        </form>
    </div>
</div>

<script>
    function setupBrandFilter(typeSelectId, brandSelectId) {
        const typeSelect = document.getElementById(typeSelectId);
        const brandSelect = document.getElementById(brandSelectId);
        // store original options in array
        const allOptions = Array.from(brandSelect.options);
        
        typeSelect.addEventListener('change', () => {
            const selectedType = typeSelect.value;
            brandSelect.innerHTML = '';
            if (brandSelectId === 'addBrandId') {
                brandSelect.add(new Option('Choose Brand', ''));
            }
            allOptions.forEach(opt => {
                if (opt.value === '') return;
                if (!selectedType || opt.dataset.type === selectedType) {
                    brandSelect.add(opt.cloneNode(true));
                }
            });
            brandSelect.value = '';
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        setupBrandFilter('addVehicleType', 'addBrandId');
        setupBrandFilter('editVehicleType', 'editBrandId');
    });

    function openEditModal(model) {
        const modal = document.getElementById('editModal');
        document.getElementById('editModelId').value = model.id;
        document.getElementById('editName').value = model.name;
        
        const typeSelect = document.getElementById('editVehicleType');
        const brandSelect = document.getElementById('editBrandId');
        
        typeSelect.value = model.brand_type;
        typeSelect.dispatchEvent(new Event('change'));
        brandSelect.value = model.brand_id;

        modal.classList.remove('hidden');
    }

    function closeEditModal() {
        document.getElementById('editModal').classList.add('hidden');
    }
</script>

<%- include('../partials/footer') %>
