<%- include('../partials/admin-header') %>

<div class="flex flex-col md:flex-row gap-8 py-6">
    <!-- Sidebar -->
    <%- include('../partials/admin-sidebar', { activeTab: 'variants' }) %>

    <!-- Main Content -->
    <main class="flex-grow space-y-8">
        <!-- Toast Container -->
        <div id="toastContainer" class="fixed top-5 right-5 z-[100] flex flex-col gap-3"></div>

        <!-- Add Variant Section -->
        <div class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100">
            <h2 class="text-2xl font-extrabold text-gray-900 mb-6 flex items-center gap-3">
                <i class="fas fa-plus-circle text-purple-600"></i> Add New Variant
            </h2>
            <form id="addVariantForm" class="grid grid-cols-1 md:grid-cols-6 gap-4 items-end">
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700 text-sm">Vehicle Type</label>
                    <select id="addVehicleType" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm">
                        <option value="">Any</option>
                        <option value="car">Car</option>
                        <option value="bike">Bike</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700 text-sm">1. Brand</label>
                    <select id="adminBrandSelect" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm" required>
                        <option value="">Select Brand</option>
                        <% brands.forEach(brand => { %>
                            <option value="<%= brand.id %>" data-type="<%= brand.type %>"><%= brand.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700 text-sm">2. Model</label>
                    <select id="adminModelSelect" name="model_id" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm" required disabled>
                        <option value="">Choose Model</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700 text-sm">3. Variant Name</label>
                    <input type="text" name="name" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm" placeholder="e.g. VXI, ZXI+" required>
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700 text-sm">4. Base Price (₹)</label>
                    <input type="number" name="base_price" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm" placeholder="e.g. 750000" step="1000" min="10000" value="500000">
                </div>
                <button type="submit" class="p-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 hover:shadow-lg transition-all uppercase tracking-wide text-sm">
                    Save Variant
                </button>
            </form>
        </div>

        <!-- Variants List -->
        <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="px-8 py-6 border-b flex flex-col xl:flex-row justify-between items-center gap-4">
                <div class="flex flex-col md:flex-row gap-4 w-full xl:w-auto">
                    <!-- Search Bar -->
                    <div class="relative w-full md:w-64">
                        <i class="fas fa-search absolute left-4 top-3.5 text-gray-400"></i>
                        <input type="text" id="variantSearchInput" placeholder="Search brand, model, variant..." class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                    </div>
                    
                    <!-- Filter Buttons -->
                    <div class="flex bg-gray-100 p-1 rounded-xl w-full md:w-auto relative z-40">
                        <button onclick="filterVariants('all')" id="filter-all" class="filter-btn flex-1 md:flex-none px-4 py-2 rounded-lg font-bold transition-all <%= currentType === 'all' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                            All <span id="count-all" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-gray-200/50 text-gray-500"><%= typeof counts !== 'undefined' ? counts.all : 0 %></span>
                        </button>
                        
                        <div class="group relative flex-1 md:flex-none">
                            <button onclick="filterVariants('car')" id="filter-car" class="filter-btn w-full px-4 py-2 rounded-lg font-bold transition-all <%= currentType === 'car' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                                Cars <span id="count-car" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-600"><%= typeof counts !== 'undefined' ? counts.car : 0 %></span>
                            </button>
                            <!-- Dropdown for Cars -->
                            <div class="hidden group-hover:block absolute left-0 top-full pt-2 w-56 z-[100]">
                                <div class="bg-white rounded-xl shadow-2xl border border-gray-100 overflow-hidden">
                                    <ul class="max-h-64 overflow-y-auto w-full">
                                        <% const carModels = models.filter(m => m.brand_type === 'car'); %>
                                        <% if (carModels.length === 0) { %>
                                            <li class="px-4 py-3 text-sm text-gray-500 italic">No car models found</li>
                                        <% } else { %>
                                            <% carModels.forEach(model => { %>
                                                <li class="border-b border-gray-50 last:border-0 hover:bg-blue-50/50 transition-colors">
                                                    <button type="button" onclick="filterVariants('car', <%= model.id %>)" class="w-full text-left px-4 py-2.5 text-sm">
                                                        <span class="block font-bold text-gray-800"><%= model.name %></span>
                                                        <span class="block text-xs text-gray-400 mt-0.5"><%= model.brand_name %></span>
                                                    </button>
                                                </li>
                                            <% }); %>
                                        <% } %>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="group relative flex-1 md:flex-none">
                            <button onclick="filterVariants('bike')" id="filter-bike" class="filter-btn w-full px-4 py-2 rounded-lg font-bold transition-all <%= currentType === 'bike' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                                Bikes <span id="count-bike" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-indigo-100 text-indigo-600"><%= typeof counts !== 'undefined' ? counts.bike : 0 %></span>
                            </button>
                            <!-- Dropdown for Bikes -->
                            <div class="hidden group-hover:block absolute right-0 md:left-0 top-full pt-2 w-56 z-[100]">
                                <div class="bg-white rounded-xl shadow-2xl border border-gray-100 overflow-hidden">
                                    <ul class="max-h-64 overflow-y-auto w-full">
                                        <% const bikeModels = models.filter(m => m.brand_type === 'bike'); %>
                                        <% if (bikeModels.length === 0) { %>
                                            <li class="px-4 py-3 text-sm text-gray-500 italic">No bike models found</li>
                                        <% } else { %>
                                            <% bikeModels.forEach(model => { %>
                                                <li class="border-b border-gray-50 last:border-0 hover:bg-indigo-50/50 transition-colors">
                                                    <button type="button" onclick="filterVariants('bike', <%= model.id %>)" class="w-full text-left px-4 py-2.5 text-sm">
                                                        <span class="block font-bold text-gray-800"><%= model.name %></span>
                                                        <span class="block text-xs text-gray-400 mt-0.5"><%= model.brand_name %></span>
                                                    </button>
                                                </li>
                                            <% }); %>
                                        <% } %>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <h2 class="text-2xl font-extrabold text-gray-900 flex items-center justify-end gap-3 w-full xl:w-auto">
                    <i class="fas fa-list text-orange-600"></i> Variants List
                </h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 text-gray-500 uppercase text-sm font-bold tracking-wider">
                        <tr>
                            <th class="px-8 py-5">ID</th>
                            <th class="px-8 py-5">Brand & Model</th>
                            <th class="px-8 py-5">Variant Name</th>
                            <th class="px-8 py-5">Base Price</th>
                            <th class="px-8 py-5">Type</th>
                            <th class="px-8 py-5 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="variantTableBody" class="divide-y divide-gray-100">
                        <% if (variants.length === 0) { %>
                            <tr><td colspan="6" class="px-8 py-10 text-center text-gray-500 italic">No variants found. Add one above!</td></tr>
                        <% } %>
                        <% variants.forEach(variant => { %>
                            <tr class="hover:bg-blue-50/30 transition-colors">
                                <td class="px-8 py-5 font-mono text-gray-400">#<%= variant.id %></td>
                                <td class="px-8 py-5">
                                    <div class="flex flex-col">
                                        <span class="text-xs text-gray-400 uppercase tracking-tighter"><%= variant.brand_name %></span>
                                        <span class="font-bold text-gray-800"><%= variant.model_name %></span>
                                    </div>
                                </td>
                                <td class="px-8 py-5 font-bold text-purple-600"><%= variant.name %></td>
                                <td class="px-8 py-5 font-mono text-emerald-600 font-bold">₹<%= variant.base_price ? Number(variant.base_price).toLocaleString('en-IN') : '5,00,000' %></td>
                                <td class="px-8 py-5">
                                    <span class="px-3 py-1 rounded-full text-xs font-bold uppercase <%= variant.brand_type === 'car' ? 'bg-blue-100 text-blue-700' : 'bg-indigo-100 text-indigo-700' %>">
                                        <%= variant.brand_type %>
                                    </span>
                                </td>
                                <td class="px-8 py-5">
                                    <div class="flex justify-center gap-3">
                                        <button onclick='openEditModal(<%= JSON.stringify(variant) %>)' class="p-2 text-blue-600 hover:bg-blue-100 rounded-lg transition-all" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button onclick="deleteVariant(<%= variant.id %>)" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-all" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<!-- Edit Modal -->
<div id="editModal" class="fixed inset-0 bg-black/50 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white p-8 rounded-3xl shadow-2xl w-full max-w-md transform transition-all scale-100">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-2xl font-extrabold text-gray-900">Edit Variant</h3>
            <button onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        <form id="editVariantForm" class="space-y-6">
            <input type="hidden" name="id" id="editVariantId">
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">Vehicle Type</label>
                <select id="editVehicleType" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="">Any</option>
                    <option value="car">Car</option>
                    <option value="bike">Bike</option>
                </select>
            </div>
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">1. Brand</label>
                <select id="editBrandId" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required>
                    <option value="">Select Brand</option>
                    <% brands.forEach(brand => { %>
                        <option value="<%= brand.id %>" data-type="<%= brand.type %>"><%= brand.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">2. Select Model</label>
                <select name="model_id" id="editModelId" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required disabled>
                    <option value="">Choose Model</option>
                </select>
            </div>
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">Variant Name</label>
                <input type="text" name="name" id="editName" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required>
            </div>
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">Base Price (₹)</label>
                <input type="number" name="base_price" id="editBasePrice" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" step="1000" min="10000">
            </div>
            <button type="submit" class="w-full p-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-all uppercase tracking-wide">
                Update Variant
            </button>
        </form>
    </div>
</div>

<script>
    // Handle cascading dropdowns for Vehicle Type -> Brand natively
    function setupBrandFilter(typeSelectId, brandSelectId) {
        const typeSelect = document.getElementById(typeSelectId);
        const brandSelect = document.getElementById(brandSelectId);
        const allOptions = Array.from(brandSelect.options);
        
        typeSelect.addEventListener('change', () => {
            const selectedType = typeSelect.value;
            brandSelect.innerHTML = '';
            brandSelect.add(new Option('Select Brand', ''));
            allOptions.forEach(opt => {
                if (opt.value === '') return;
                if (!selectedType || opt.dataset.type === selectedType) {
                    brandSelect.add(opt.cloneNode(true));
                }
            });
            brandSelect.value = '';
            // Reset dependent models
            brandSelect.dispatchEvent(new Event('change'));
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        setupBrandFilter('addVehicleType', 'adminBrandSelect');
        setupBrandFilter('editVehicleType', 'editBrandId');
    });

    // Handle cascading dropdown for Brand -> Model dynamically
    async function bindModelsToBrand(brandSelectId, modelSelectId) {
        const brandSelect = document.getElementById(brandSelectId);
        const modelSelect = document.getElementById(modelSelectId);

        brandSelect.addEventListener('change', async () => {
            const brandId = brandSelect.value;
            modelSelect.innerHTML = '<option value="">Loading...</option>';
            modelSelect.disabled = true;

            if (!brandId) {
                modelSelect.innerHTML = '<option value="">Choose Model</option>';
                return;
            }

            try {
                const response = await fetch(`/api/models?brand_id=${brandId}`);
                const models = await response.json();
                
                modelSelect.innerHTML = '<option value="">Choose Model</option>';
                models.forEach(model => {
                    const opt = document.createElement('option');
                    opt.value = model.id;
                    opt.textContent = model.name;
                    modelSelect.appendChild(opt);
                });
                modelSelect.disabled = false;
            } catch (error) {
                console.error('Error fetching models:', error);
                modelSelect.innerHTML = '<option value="">Error loading</option>';
            }
        });
    }

    bindModelsToBrand('adminBrandSelect', 'adminModelSelect');
    bindModelsToBrand('editBrandId', 'editModelId');

    async function openEditModal(variant) {
        const modal = document.getElementById('editModal');
        document.getElementById('editVariantId').value = variant.id;
        document.getElementById('editName').value = variant.name;
        document.getElementById('editBasePrice').value = variant.base_price || 500000;
        
        const typeSelect = document.getElementById('editVehicleType');
        const brandSelect = document.getElementById('editBrandId');
        const modelSelect = document.getElementById('editModelId');

        typeSelect.value = variant.brand_type;
        typeSelect.dispatchEvent(new Event('change')); // Filters Brands
        brandSelect.value = variant.brand_id;

        // Manually fetch models to await completion before setting index
        try {
            modelSelect.innerHTML = '<option value="">Loading...</option>';
            modelSelect.disabled = true;
            const res = await fetch(`/api/models?brand_id=${variant.brand_id}`);
            const models = await res.json();
            
            modelSelect.innerHTML = '<option value="">Choose Model</option>';
            models.forEach(model => {
                const opt = document.createElement('option');
                opt.value = model.id;
                opt.textContent = model.name;
                modelSelect.appendChild(opt);
            });
            modelSelect.disabled = false;
            modelSelect.value = variant.model_id;
        } catch (e) { console.error(e); }

        modal.classList.remove('hidden');
    }

    function closeEditModal() {
        document.getElementById('editModal').classList.add('hidden');
    }
</script>

<%- include('../partials/footer') %>
