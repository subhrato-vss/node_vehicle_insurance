<%- include('../partials/admin-header') %>

<div class="flex flex-col md:flex-row gap-8 py-6">
    <!-- Sidebar -->
    <%- include('../partials/admin-sidebar', { activeTab: 'brands' }) %>

    <!-- Main Content -->
    <main class="flex-grow space-y-8">
        <!-- Toast Container -->
        <div id="toastContainer" class="fixed top-5 right-5 z-[100] flex flex-col gap-3"></div>

        <!-- Add Brand Section -->
        <div class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100">
            <h2 class="text-2xl font-extrabold text-gray-900 mb-6 flex items-center gap-3">
                <i class="fas fa-plus-circle text-blue-600"></i> Add New Brand
            </h2>
            <form id="addBrandForm" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
                <div class="space-y-2 col-span-1 md:col-span-1">
                    <label class="block font-bold text-gray-700">Brand Name</label>
                    <input type="text" name="name" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. Maruti, Honda" required>
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-gray-700">Vehicle Type</label>
                    <select name="type" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required>
                        <option value="car">Car</option>
                        <option value="bike">Bike</option>
                    </select>
                </div>
                <button type="submit" class="p-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 hover:shadow-lg transition-all uppercase tracking-wide">
                    Save Brand
                </button>
            </form>
        </div>

        <!-- Brands List -->
        <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="px-8 py-6 border-b flex flex-col md:flex-row justify-between items-center gap-4">
                <h2 class="text-2xl font-extrabold text-gray-900 flex items-center gap-3">
                    <i class="fas fa-list text-indigo-600"></i> Brands List
                </h2>
                <!-- Filter Buttons -->
                <div class="flex bg-gray-100 p-1 rounded-xl w-full md:w-auto">
                    <button onclick="filterBrands('all')" id="filter-all" class="filter-btn flex-1 md:flex-none px-6 py-2 rounded-lg font-bold transition-all <%= currentType === 'all' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                        All <span id="count-all" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-gray-200/50 text-gray-500"><%= typeof counts !== 'undefined' ? counts.all : 0 %></span>
                    </button>
                    <button onclick="filterBrands('car')" id="filter-car" class="filter-btn flex-1 md:flex-none px-6 py-2 rounded-lg font-bold transition-all <%= currentType === 'car' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                        Cars <span id="count-car" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-600"><%= typeof counts !== 'undefined' ? counts.car : 0 %></span>
                    </button>
                    <button onclick="filterBrands('bike')" id="filter-bike" class="filter-btn flex-1 md:flex-none px-6 py-2 rounded-lg font-bold transition-all <%= currentType === 'bike' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
                        Bikes <span id="count-bike" class="ml-1 text-xs px-2 py-0.5 rounded-full bg-indigo-100 text-indigo-600"><%= typeof counts !== 'undefined' ? counts.bike : 0 %></span>
                    </button>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 text-gray-500 uppercase text-sm font-bold tracking-wider">
                        <tr>
                            <th class="px-8 py-5">ID</th>
                            <th class="px-8 py-5">Name</th>
                            <th class="px-8 py-5">Type</th>
                            <th class="px-8 py-5 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="brandTableBody" class="divide-y divide-gray-100">
                        <% if (brands.length === 0) { %>
                            <tr><td colspan="4" class="px-8 py-10 text-center text-gray-500 italic">No brands found. Add one above!</td></tr>
                        <% } %>
                        <% brands.forEach(brand => { %>
                            <tr class="hover:bg-blue-50/30 transition-colors">
                                <td class="px-8 py-5 font-mono text-gray-400">#<%= brand.id %></td>
                                <td class="px-8 py-5 font-bold text-gray-800"><%= brand.name %></td>
                                <td class="px-8 py-5">
                                    <span class="px-3 py-1 rounded-full text-xs font-bold uppercase <%= brand.type === 'car' ? 'bg-blue-100 text-blue-700' : 'bg-indigo-100 text-indigo-700' %>">
                                        <%= brand.type %>
                                    </span>
                                </td>
                                <td class="px-8 py-5">
                                    <div class="flex justify-center gap-3">
                                        <!-- Simple edit/delete buttons -->
                                        <button onclick="openEditModal(<%= JSON.stringify(brand) %>)" class="p-2 text-blue-600 hover:bg-blue-100 rounded-lg transition-all" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button onclick="deleteBrand(<%= brand.id %>)" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-all" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<!-- Edit Modal -->
<div id="editModal" class="fixed inset-0 bg-black/50 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white p-8 rounded-3xl shadow-2xl w-full max-w-md transform transition-all scale-100">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-2xl font-extrabold text-gray-900">Edit Brand</h3>
            <button onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        <form id="editBrandForm" class="space-y-6">
            <input type="hidden" name="id" id="editBrandId">
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">Brand Name</label>
                <input type="text" name="name" id="editName" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required>
            </div>
            <div class="space-y-2">
                <label class="block font-bold text-gray-700">Vehicle Type</label>
                <select name="type" id="editType" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" required>
                    <option value="car">Car</option>
                    <option value="bike">Bike</option>
                </select>
            </div>
            <button type="submit" class="w-full p-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-all uppercase tracking-wide">
                Update Brand
            </button>
        </form>
    </div>
</div>

<script>
    function openEditModal(brand) {
        const modal = document.getElementById('editModal');
        document.getElementById('editBrandId').value = brand.id;
        document.getElementById('editName').value = brand.name;
        document.getElementById('editType').value = brand.type;
        modal.classList.remove('hidden');
    }

    function closeEditModal() {
        document.getElementById('editModal').classList.add('hidden');
    }
</script>

<%- include('../partials/footer') %>
