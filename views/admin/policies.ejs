<%- include('../partials/admin-header') %>

<div class="flex flex-col md:flex-row gap-8 py-6">
    <!-- Sidebar -->
    <%- include('../partials/admin-sidebar', { activeTab: 'policies' }) %>

    <!-- Main Content -->
    <main class="flex-grow space-y-8">
        <!-- Page Header -->
        <div class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100 flex flex-col md:flex-row justify-between items-center gap-6">
            <div>
                <h1 class="text-3xl font-extrabold text-gray-900 flex items-center gap-3">
                    <i class="fas fa-file-invoice text-blue-600"></i> Policy Management
                </h1>
                <p class="text-gray-500 mt-2">View and manage all finalized insurance policies issued to customers.</p>
            </div>
            <!-- Search Bar -->
            <div class="relative w-full md:w-96">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                <input type="text" id="policySearchInput" placeholder="Search by Policy No or Name..." class="w-full pl-12 pr-4 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none transition-all font-medium">
            </div>
        </div>

        <!-- Policies Table -->
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-gray-50/50 text-gray-400 text-xs font-bold uppercase tracking-widest border-b border-gray-100">
                        <tr>
                            <th class="px-8 py-5">Policy Details</th>
                            <th class="px-8 py-5">Customer info</th>
                            <th class="px-8 py-5">Vehicle info</th>
                            <th class="px-8 py-5">Plan & Premium</th>
                            <th class="px-8 py-5">Expiry Date</th>
                            <th class="px-8 py-5">Status</th>
                            <th class="px-8 py-5 text-right">Download</th>
                        </tr>
                    </thead>
                    <tbody id="policyTableBody" class="divide-y divide-gray-50">
                        <% if (policies && policies.length > 0) { %>
                            <% policies.forEach(p => { %>
                                <tr class="hover:bg-blue-50/30 transition-colors group">
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="text-blue-600 font-extrabold text-lg"><%= p.policy_number %></span>
                                            <span class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter mt-0.5">Issued: <%= new Date(p.created_at).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="font-bold text-gray-800"><%= p.customer_name %></span>
                                            <span class="text-xs text-gray-500"><%= p.customer_email %></span>
                                            <span class="text-[10px] text-gray-400 font-medium"><%= p.customer_mobile %></span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="text-xs text-gray-400 uppercase tracking-tighter"><%= p.brand_name %></span>
                                            <span class="font-bold text-gray-700"><%= p.variant_name %></span>
                                            <span class="text-[10px] text-gray-500"><%= p.fuel_type %> • <%= p.manufacturing_year %></span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="text-xs font-bold text-gray-500 bg-gray-100 self-start px-2 py-0.5 rounded-full mb-1"><%= p.plan_name %></span>
                                            <span class="text-lg font-black text-gray-900">₹<%= Number(p.final_premium).toLocaleString('en-IN') %></span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="text-xs font-bold text-gray-700"><%= new Date(p.end_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                                            <span class="text-[10px] text-gray-400 font-medium">at 23:59:59</span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <% 
                                            const statusColors = {
                                                'active': 'bg-green-100 text-green-700',
                                                'expiring': 'bg-yellow-100 text-yellow-700',
                                                'expired': 'bg-red-100 text-red-700'
                                            };
                                            const color = statusColors[p.status] || 'bg-gray-100 text-gray-700';
                                        %>
                                        <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase <%= color %> shadow-sm">
                                            <%= p.status %>
                                        </span>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <a href="/policies/POLICY_<%= p.policy_number %>.pdf" download class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-gray-50 text-gray-400 group-hover:bg-blue-600 group-hover:text-white transition-all shadow-sm border border-gray-100 hover:scale-110 active:scale-95" title="Download Policy PDF">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="px-8 py-20 text-center">
                                    <div class="flex flex-col items-center gap-4">
                                        <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center">
                                            <i class="fas fa-file-invoice text-4xl text-gray-200"></i>
                                        </div>
                                        <p class="text-gray-500 font-bold italic">No policies recorded in the system yet.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<script>
    document.getElementById('policySearchInput').addEventListener('input', function() {
        const query = this.value.toLowerCase();
        const rows = document.querySelectorAll('#policyTableBody tr');
        
        rows.forEach(row => {
            if (row.querySelector('td[colspan]')) return;
            const text = row.innerText.toLowerCase();
            row.style.display = text.includes(query) ? '' : 'none';
        });
    });
</script>

<%- include('../partials/footer') %>
