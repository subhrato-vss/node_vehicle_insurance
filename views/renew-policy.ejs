<%- include('partials/header') %>

<script>
    window.RAZORPAY_TEST_KEY = "<%= razorpayKey %>";
    window.RENEWAL_POLICY_ID = "<%= policy.id %>";
    window.OLD_PREMIUM = <%= policy.final_premium %>;
    window.POLICY_DATA = <%- JSON.stringify(policy) %>;
</script>

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-white p-6 sm:p-10 rounded-3xl shadow-2xl border border-gray-100">
        
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8 border-b pb-6 border-gray-100">
            <div class="flex items-center gap-6">
                <div class="w-16 h-16 bg-orange-50 rounded-2xl flex items-center justify-center text-orange-500 shadow-sm border border-orange-100">
                    <i class="fas fa-sync-alt text-3xl"></i>
                </div>
                <div>
                    <h2 class="text-3xl font-extrabold text-gray-900">Renew Policy</h2>
                    <p class="text-sm font-medium text-gray-500 mt-1 uppercase tracking-wider">Policy: <%= policy.policy_number %></p>
                </div>
            </div>
            <div class="text-right">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold bg-yellow-100 text-yellow-800 border border-yellow-200">
                    <i class="fas fa-exclamation-circle mr-2"></i> Action Required
                </span>
            </div>
        </div>

        <div id="renewalLoader" class="py-16 text-center">
            <i class="fas fa-circle-notch fa-spin text-4xl text-blue-500 mb-4"></i>
            <p class="text-gray-500 font-bold">Recalculating fresh premium rates...</p>
        </div>

        <!-- Dynamic Content Injected via JS -->
        <div id="renewalContent" class="hidden space-y-8">
            
            <!-- Comparison Card -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2"><i class="fas fa-history mr-1"></i> Original Premium</p>
                    <p class="text-3xl font-extrabold text-gray-400">₹<%= Number(policy.final_premium).toLocaleString('en-IN') %></p>
                    <p class="text-xs text-gray-400 mt-2 font-medium">From previous year's rating</p>
                </div>
                <div class="bg-gradient-to-br from-indigo-50 to-blue-50 rounded-2xl p-6 border border-blue-100 shadow-sm relative overflow-hidden">
                    <div class="absolute -right-4 -bottom-4 text-blue-100 opacity-50"><i class="fas fa-shield-check text-8xl"></i></div>
                    <p class="text-xs font-bold text-blue-600 uppercase tracking-widest mb-2"><i class="fas fa-bolt mr-1"></i> New Premium Value</p>
                    <p class="text-4xl font-extrabold text-blue-700" id="newPremiumAmt">₹0</p>
                    <p class="text-xs text-blue-500 mt-2 font-medium" id="premiumDiffLabel">Calculating changes based on age depreciation...</p>
                </div>
            </div>

            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
                <div class="p-4 bg-gray-50 border-b border-gray-200 font-bold text-gray-700">
                    <i class="fas fa-clipboard-check text-blue-500 mr-2"></i> Verify Your Information
                </div>
                <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
                    <div>
                        <p class="text-[10px] text-gray-400 uppercase tracking-wide">Vehicle Details</p>
                        <p class="font-bold text-gray-900 mt-1 capitalize"><%= policy.vehicle_type %> - <%= policy.manufacturing_year %> (RTO: <%= policy.rto_city %>)</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 uppercase tracking-wide">Insured Declared Value (IDV)</p>
                        <p class="font-bold text-emerald-600 border border-emerald-200 bg-emerald-50 inline-block px-2 py-0.5 rounded mt-1" id="newIdvAmt">₹0</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 uppercase tracking-wide">Policy Holder</p>
                        <p class="font-bold text-gray-900 mt-1"><%= policy.customer_name %></p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 uppercase tracking-wide">Contact Details</p>
                        <p class="font-bold text-gray-600 mt-1"><%= policy.customer_mobile %> | <%= policy.customer_email %></p>
                    </div>
                </div>
            </div>

            <!-- Payment Button -->
            <div class="pt-6 border-t border-gray-100">
                <button type="button" id="btnPayRenewal" class="w-full py-4 bg-gradient-to-r from-blue-600 to-indigo-700 text-white font-extrabold text-lg rounded-2xl shadow-xl hover:shadow-2xl hover:scale-[1.02] active:scale-95 transition-all mb-3 flex items-center justify-center gap-3 disabled:opacity-50">
                    <i class="fas fa-lock"></i>
                    Pay & Instantly Renew
                </button>
                <p class="text-center text-xs text-gray-500 font-medium">Secured by Razorpay. Policy downloads instantly upon payment success.</p>
            </div>

        </div>

        <!-- Success Confirmation -->
        <div id="successOverlay" class="hidden animate-fade-in text-center py-8">
            <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-5"><i class="fas fa-check text-4xl text-emerald-600"></i></div>
            <h3 class="text-2xl font-extrabold text-gray-900 mb-2">Renewal Successful!</h3>
            <p class="text-gray-500 mb-4 max-w-sm mx-auto">Your insurance policy has been safely renewed. Coverage starts immediately.</p>
            <a href="/user/dashboard" class="inline-block mt-4 px-8 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all"><i class="fas fa-home mr-2"></i> Return to Dashboard</a>
        </div>

    </div>
</div>

<script src="/js/renewal.js"></script>
<%- include('partials/footer') %>
