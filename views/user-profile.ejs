<%- include('partials/header') %>

<div class="flex min-h-screen bg-gray-50">
    <!-- Sidebar -->
    <%- include('partials/user-sidebar', { activeTab: 'profile' }) %>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto">
        <div class="max-w-4xl mx-auto p-4 sm:p-6 lg:p-8">
            
            <!-- Breadcrumbs -->
            <div class="mb-8 flex items-center gap-2 text-sm font-medium text-gray-500">
                <a href="/user/dashboard" class="hover:text-blue-600 transition-colors">Dashboard</a>
                <i class="fas fa-chevron-right text-[10px]"></i>
                <span class="text-gray-900 font-bold">Account Profile</span>
            </div>

            <!-- Page Header -->
            <div class="mb-8">
                <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Your Profile</h1>
                <p class="text-gray-500 mt-1">Manage your account information and preferences.</p>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-gray-200 overflow-hidden">
                <!-- Profile Header Banner -->
                <div class="h-32 bg-gradient-to-r from-blue-600 to-indigo-700 relative">
                    <div class="absolute -bottom-12 left-8">
                        <div class="w-24 h-24 rounded-3xl bg-white p-1.5 shadow-xl border border-white">
                            <div class="w-full h-full rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 text-3xl font-black uppercase">
                                <%= user.name ? user.name.charAt(0) : 'U' %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pt-16 pb-10 px-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <!-- Basic Info Section -->
                        <div class="space-y-6">
                            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest flex items-center gap-2">
                                <i class="fas fa-info-circle text-blue-500"></i> Basic Information
                            </h3>
                            
                            <div class="space-y-4">
                                <!-- Full Name -->
                                <div class="bg-gray-50/50 p-4 rounded-2xl border border-transparent hover:border-gray-200 transition-all group">
                                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-tight mb-0.5">Full Name</p>
                                    <p class="text-gray-900 font-extrabold text-lg"><%= user.name %></p>
                                </div>

                                <!-- Email -->
                                <div class="bg-gray-50/50 p-4 rounded-2xl border border-transparent hover:border-gray-200 transition-all">
                                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-tight mb-0.5">Email Address</p>
                                    <div class="flex items-center gap-2">
                                        <p class="text-gray-900 font-bold"><%= user.email %></p>
                                        <span class="bg-green-100 text-green-700 text-[10px] font-bold px-2 py-0.5 rounded-full flex items-center gap-1">
                                            <i class="fas fa-check-circle text-[8px]"></i> Verified
                                        </span>
                                    </div>
                                </div>

                                <!-- Mobile -->
                                <div class="bg-gray-50/50 p-4 rounded-2xl border border-transparent hover:border-gray-200 transition-all">
                                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-tight mb-0.5">Mobile Number</p>
                                    <p class="text-gray-900 font-bold"><%= user.mobile || 'N/A' %></p>
                                </div>
                            </div>
                        </div>

                        <!-- System Info / Preferences -->
                        <div class="space-y-6">
                            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest flex items-center gap-2">
                                <i class="fas fa-cog text-indigo-500"></i> Account Details
                            </h3>
                            
                            <div class="space-y-4">
                                <!-- Member Since -->
                                <div class="bg-gray-50/50 p-4 rounded-2xl border border-transparent hover:border-gray-200 transition-all">
                                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-tight mb-0.5">Member Since</p>
                                    <p class="text-gray-900 font-bold">
                                        <%= new Date(user.created_at).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                                    </p>
                                </div>

                                <!-- Account Role -->
                                <div class="bg-gray-50/50 p-4 rounded-2xl border border-transparent hover:border-gray-200 transition-all">
                                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-tight mb-0.5">Account Type</p>
                                    <span class="inline-flex items-center gap-2 text-indigo-600 font-bold">
                                        <i class="fas fa-shield-alt"></i> Standard Customer
                                    </span>
                                </div>
                            </div>

                            <!-- CTA / Info Box -->
                            <div class="mt-10 p-6 rounded-3xl bg-blue-50 border border-blue-100">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-2xl bg-white flex items-center justify-center text-blue-600 shadow-sm border border-blue-100 flex-shrink-0">
                                        <i class="fas fa-headset"></i>
                                    </div>
                                    <div>
                                        <p class="font-bold text-blue-900 text-sm">Need to update information?</p>
                                        <p class="text-xs text-blue-700/70 mt-1 leading-relaxed">For security reasons, changing your primary email or phone number requires verification. Please contact support.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
