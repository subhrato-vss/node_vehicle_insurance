<%- include('partials/header') %>

<div class="flex min-h-screen bg-gray-50">
    <%- include('partials/user-sidebar', { activeTab: 'dashboard' }) %>

    <main class="flex-1 overflow-y-auto">
        <div class="max-w-4xl mx-auto p-4 sm:p-6 lg:p-8">
            <div class="mb-8">
                <a href="/user/dashboard" class="text-blue-600 hover:text-blue-800 font-bold flex items-center gap-2 mb-4">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
                <h1 class="text-3xl font-extrabold text-gray-900">Raise an Insurance Claim</h1>
                <p class="text-gray-500 mt-1">Please provide accurate details along with document proofs.</p>
            </div>

            <!-- Claim Form Container -->
            <div class="bg-white rounded-2xl shadow-xl shadow-slate-200 border border-slate-100 p-8">
                <div class="flex items-center gap-4 p-4 bg-blue-50/50 rounded-xl mb-8 border border-blue-100">
                    <div class="w-12 h-12 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center text-xl">
                        <i class="fas fa-file-contract"></i>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-blue-600 uppercase tracking-wider">Policy Details</p>
                        <p class="text-lg font-bold text-gray-900"><%= policy.policy_number %> — <%= policy.plan_name %></p>
                    </div>
                </div>

                <form id="claimForm" class="space-y-6" enctype="multipart/form-data">
                    <input type="hidden" name="policyId" value="<%= policy.id %>">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Claim Reason -->
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Claim Reason <span class="text-red-500">*</span></label>
                            <select name="claimReason" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition-all outline-none">
                                <option value="" disabled selected>Select a reason</option>
                                <option value="Accident">Accident</option>
                                <option value="Theft">Theft</option>
                                <option value="Damage">Damage</option>
                            </select>
                        </div>
                        
                        <!-- Claim Amount -->
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Claim Amount (₹) <span class="text-red-500">*</span></label>
                            <input type="number" name="claimAmount" placeholder="Enter estimated amount" required max="<%= policy.idv %>" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition-all outline-none">
                            <p class="text-xs text-slate-400 mt-1.5 font-medium">Max IDV: ₹<%= parseFloat(policy.idv).toLocaleString('en-IN') %></p>
                        </div>
                    </div>

                    <!-- Description -->
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Detailed Description <span class="text-red-500">*</span></label>
                        <textarea name="description" rows="4" placeholder="Describe how it happened..." required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition-all outline-none resize-none"></textarea>
                    </div>

                    <!-- Uploads Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 p-6 bg-slate-50 rounded-2xl border border-dashed border-slate-300">
                        <!-- RC Copy -->
                        <div class="relative group">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">RC Copy <span class="text-red-500">*</span></label>
                            <input type="file" name="rc_copy" required accept="image/*,.pdf" class="w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-blue-100 file:text-blue-700 hover:file:bg-blue-200 transition-all cursor-pointer">
                        </div>
                        <!-- DL -->
                        <div class="relative group">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Driving License <span class="text-red-500">*</span></label>
                            <input type="file" name="driving_license" required accept="image/*,.pdf" class="w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-blue-100 file:text-blue-700 hover:file:bg-blue-200 transition-all cursor-pointer">
                        </div>
                        <!-- Damage Photos -->
                        <div class="relative group">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Photos (Damage) <span class="text-red-500">*</span></label>
                            <input type="file" name="damage_photo" multiple required accept="image/*" class="w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-blue-100 file:text-blue-700 hover:file:bg-blue-200 transition-all cursor-pointer">
                        </div>
                    </div>

                    <p class="text-xs text-amber-600 bg-amber-50 p-3 rounded-lg border border-amber-100 flex items-start gap-2">
                        <i class="fas fa-info-circle mt-0.5"></i>
                        <span>By clicking submit, you certify that the information provided is true. False claims may result in policy cancellation or legal action.</span>
                    </p>

                    <!-- Submit -->
                    <button type="submit" id="btnSubmit" class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-extrabold rounded-2xl shadow-lg shadow-blue-200 flex items-center justify-center gap-2 transition-all transform active:scale-[0.98]">
                        <i class="fas fa-paper-plane"></i> Submit Insurance Claim
                    </button>
                    
                    <div id="loading" class="hidden text-center py-4 text-blue-600">
                        <i class="fas fa-circle-notch fa-spin text-3xl"></i>
                        <p class="text-sm font-bold mt-2">Uploading documents... Please wait</p>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>

<script>
document.getElementById('claimForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('btnSubmit');
    const loading = document.getElementById('loading');
    const formData = new FormData(this);

    btn.classList.add('hidden');
    loading.classList.remove('hidden');

    try {
        const response = await fetch('/api/claim/create', { method: 'POST', body: formData });
        const result = await response.json();

        if (result.success) {
            Swal.fire({
                title: 'Claim Submitted!',
                text: 'Your claim request has been received. Our agents will contact you shortly.',
                icon: 'success',
                confirmButtonColor: '#2563eb',
                confirmButtonText: 'View My Claims'
            }).then(() => {
                window.location.href = '/user/claims';
            });
        } else {
            Swal.fire('Error', result.message, 'error');
            btn.classList.remove('hidden');
            loading.classList.add('hidden');
        }
    } catch (error) {
        console.error('Submission error:', error);
        Swal.fire('Network Error', 'Check your connection and try again.', 'error');
        btn.classList.remove('hidden');
        loading.classList.add('hidden');
    }
});
</script>

<%- include('partials/footer') %>
