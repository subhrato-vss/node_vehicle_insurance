<%- include('partials/header') %>

<div class="max-w-4xl mx-auto py-12 px-4">
    <!-- Success Celebration Header -->
    <div class="text-center mb-12 animate-fade-in">
        <div class="inline-flex items-center justify-center w-24 h-24 bg-emerald-100 rounded-full mb-6 shadow-sm border-4 border-white ring-8 ring-emerald-50/50">
            <i class="fas fa-check text-4xl text-emerald-600"></i>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tight">Congratulations!</h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto">Your <span class="text-blue-600 font-bold"><%= policy.brand_name %> <%= policy.model_name %></span> is now fully protected with DriveGuard.</p>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        
        <!-- Left: Policy Card -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Digital Policy Card -->
            <div class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 rounded-[2.5rem] shadow-2xl overflow-hidden relative border border-white/10">
                <!-- Decorative elements -->
                <div class="absolute -right-20 -top-20 w-64 h-64 bg-blue-500 rounded-full opacity-10 blur-3xl"></div>
                <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-emerald-500 rounded-full opacity-10 blur-3xl"></div>
                
                <div class="p-8 md:p-10 relative z-10">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
                        <div>
                            <p class="text-blue-400 text-xs font-black uppercase tracking-[0.2em] mb-2">Policy Secured</p>
                            <h2 class="text-3xl font-mono text-white font-black tracking-wider"><%= policy.policy_number %></h2>
                        </div>
                        <div class="px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full">
                            <span class="flex items-center gap-2 text-emerald-400 text-xs font-bold uppercase tracking-widest">
                                <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                                Active Status
                            </span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 border-t border-white/5 pt-8">
                        <div>
                            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-3">Policy Holder</p>
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-xl text-blue-400 font-bold border border-white/10">
                                    <%= policy.customer_name.charAt(0) %>
                                </div>
                                <div>
                                    <p class="text-white font-extrabold text-lg leading-tight"><%= policy.customer_name %></p>
                                    <p class="text-slate-400 text-sm"><%= policy.customer_email %></p>
                                </div>
                            </div>
                        </div>

                        <div>
                            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-3">Insured Vehicle</p>
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-xl text-indigo-400 border border-white/10">
                                    <i class="fas fa-<%= policy.vehicle_type === 'car' ? 'car' : 'motorcycle' %>"></i>
                                </div>
                                <div>
                                    <p class="text-white font-extrabold text-lg leading-tight"><%= policy.brand_name %> <%= policy.model_name %></p>
                                    <p class="text-slate-400 text-sm"><%= policy.variant_name %></p>
                                </div>
                            </div>
                        </div>

                        <div>
                            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-3">Plan Details</p>
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-xl text-violet-400 border border-white/10">
                                    <i class="fas fa-shield-halved"></i>
                                </div>
                                <div>
                                    <p class="text-white font-extrabold text-lg leading-tight"><%= policy.plan_name %></p>
                                    <p class="text-slate-400 text-sm">Comprehensive Coverage</p>
                                </div>
                            </div>
                        </div>

                        <div>
                            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-3">Premium Paid</p>
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-xl text-emerald-400 border border-white/10">
                                    <i class="fas fa-rupee-sign"></i>
                                </div>
                                <div>
                                    <p class="text-white font-extrabold text-2xl leading-tight">₹<%= Number(policy.final_premium).toLocaleString('en-IN') %></p>
                                    <p class="text-slate-400 text-sm">Inclusive of Taxes</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card Footer Action -->
                <div class="bg-white/5 border-t border-white/10 p-6 flex flex-col md:flex-row justify-between items-center gap-4">
                    <p class="text-slate-400 text-sm flex items-center gap-2">
                        <i class="fas fa-calendar-check text-blue-400"></i>
                        Valid until <%= new Date(policy.end_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </p>
                    <a href="/policies/POLICY_<%= policy.policy_number %>.pdf" target="_blank" download class="px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition-all flex items-center gap-2 shadow-lg hover:shadow-blue-500/20">
                        <i class="fas fa-download"></i> Download PDF
                    </a>
                </div>
            </div>

            <!-- Dashboard Call to Action (The "Login" Link) -->
            <div class="bg-indigo-600 rounded-[2rem] p-8 text-white relative overflow-hidden shadow-xl shadow-indigo-200 group">
                <div class="absolute right-0 top-0 bottom-0 w-1/3 bg-gradient-to-l from-white/10 to-transparent"></div>
                <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="text-center md:text-left">
                        <h3 class="text-2xl font-black mb-2">Access Your Dashboard</h3>
                        <p class="text-indigo-100 opacity-90 max-w-md">Manage your policy, file claims, and download receipts anytime from your personalized customer portal.</p>
                    </div>
                    <a href="/user/login?email=<%= encodeURIComponent(email) %>" class="whitespace-nowrap px-8 py-4 bg-white text-indigo-600 font-black rounded-2xl shadow-xl hover:scale-105 active:scale-95 transition-all flex items-center gap-3">
                        Login Now <i class="fas fa-arrow-right animate-bounce-x"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Right: What's Next / Info -->
        <div class="space-y-6">
            <div class="bg-white rounded-[2rem] p-8 border border-gray-100 shadow-sm">
                <h4 class="font-black text-gray-900 mb-6 uppercase tracking-widest text-xs">What's Next?</h4>
                <div class="space-y-8">
                    <div class="flex gap-4">
                        <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center flex-shrink-0 font-bold border border-blue-100 italic">1</div>
                        <div>
                            <p class="font-bold text-gray-900 text-sm mb-1">Check Your Inbox</p>
                            <p class="text-xs text-gray-500 leading-relaxed">We've sent the policy document and payment receipt to <span class="font-bold text-gray-700"><%= policy.customer_email %></span>.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div class="w-10 h-10 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center flex-shrink-0 font-bold border border-emerald-100 italic">2</div>
                        <div>
                            <p class="font-bold text-gray-900 text-sm mb-1">Login to Account</p>
                            <p class="text-xs text-gray-500 leading-relaxed">Use the link on the left to login. Your account was automatically created during purchase.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div class="w-10 h-10 bg-violet-50 text-violet-600 rounded-xl flex items-center justify-center flex-shrink-0 font-bold border border-violet-100 italic">3</div>
                        <div>
                            <p class="font-bold text-gray-900 text-sm mb-1">Stay Protected</p>
                            <p class="text-xs text-gray-500 leading-relaxed">Your coverage is active immediately. Drive safely with DriveGuard by your side.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-slate-50 rounded-[2rem] p-8 border border-dashed border-slate-200 text-center">
                <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mb-4 italic">Need Help?</p>
                <p class="text-sm text-slate-600 mb-6">Our support team is available 24/7 for any assistance.</p>
                <div class="flex flex-col gap-3">
                    <a href="tel:1800-DRIVE-GUARD" class="text-slate-900 font-bold hover:text-blue-600 transition-colors flex items-center justify-center gap-2">
                        <i class="fas fa-phone-alt text-xs"></i> 1800-DRIVE-GUARD
                    </a>
                    <a href="/" class="text-blue-600 font-bold hover:underline">Return to Home</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @keyframes bounce-x {
        0%, 100% { transform: translateX(0); }
        50% { transform: translateX(5px); }
    }
    .animate-bounce-x {
        animation: bounce-x 1s infinite;
    }
    .animate-fade-in {
        animation: fadeIn 1s ease-out;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<%- include('partials/footer') %>
