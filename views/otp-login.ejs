<%- include('partials/header') %>

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-3xl shadow-xl border border-gray-100">
        
        <!-- Header -->
        <div class="text-center">
            <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-4 border border-blue-100">
                <i class="fas fa-shield-alt text-2xl text-blue-600"></i>
            </div>
            <h2 class="text-3xl font-extrabold text-gray-900" id="formTitle">Secure Login</h2>
            <p class="mt-2 text-sm text-gray-600" id="formSubtitle">
                Access your DriveGuard dashboard using a standard One-Time Password.
            </p>
        </div>

        <div id="alertBox" class="hidden rounded-md p-4 text-sm font-medium"></div>

        <!-- Step 1: Request OTP Form -->
        <form id="requestOtpForm" class="mt-8 space-y-6">
            <div class="rounded-md shadow-sm">
                <div>
                    <label for="emailInput" class="block text-sm font-bold text-gray-700 mb-2">Email Address</label>
                    <input id="emailInput" type="email" required class="appearance-none rounded-xl relative block w-full px-4 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-all" placeholder="Enter your registered email">
                </div>
            </div>

            <div>
                <button type="submit" id="btnRequestOtp" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-extrabold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200">
                    Send Verification Code
                </button>
            </div>
        </form>

        <!-- Step 2: Verify OTP Form (Hidden by default) -->
        <form id="verifyOtpForm" class="mt-8 space-y-6 hidden">
            
            <div class="rounded-md shadow-sm">
                <label class="block text-sm font-bold text-gray-700 mb-2 text-center">Enter 6-Digit Code</label>
                <!-- Interactive 6-Digit Array Layout -->
                <div class="flex justify-center gap-2 mb-4" id="otpContainer">
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-2xl font-extrabold border-2 border-gray-300 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-2xl font-extrabold border-2 border-gray-300 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-2xl font-extrabold border-2 border-gray-300 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-2xl font-extrabold border-2 border-gray-300 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-2xl font-extrabold border-2 border-gray-300 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-2xl font-extrabold border-2 border-gray-300 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all otp-input">
                </div>
                <input type="hidden" id="fullOtpCode">
            </div>

            <div>
                <button type="submit" id="btnVerifyOtp" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-extrabold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-200">
                    Verify Code & Login
                </button>
            </div>
            
            <div class="text-center mt-4">
                <button type="button" id="btnResend" class="text-sm font-bold text-gray-400 hover:text-blue-600 transition-colors" disabled>
                    Resend Code <span id="timerSpan">(05:00)</span>
                </button>
                <div class="mt-4">
                    <button type="button" id="btnChangeEmail" class="text-xs font-bold text-blue-500 hover:text-blue-700 transition-colors">
                        Wrong email? Go back.
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const requestOtpForm = document.getElementById('requestOtpForm');
    const verifyOtpForm = document.getElementById('verifyOtpForm');
    const emailInput = document.getElementById('emailInput');
    const fullOtpCode = document.getElementById('fullOtpCode');
    
    const btnRequestOtp = document.getElementById('btnRequestOtp');
    const btnVerifyOtp = document.getElementById('btnVerifyOtp');
    const btnChangeEmail = document.getElementById('btnChangeEmail');
    const btnResend = document.getElementById('btnResend');
    const timerSpan = document.getElementById('timerSpan');
    
    const formSubtitle = document.getElementById('formSubtitle');
    const alertBox = document.getElementById('alertBox');
    const otpInputs = document.querySelectorAll('.otp-input');

    let activeEmail = '';
    let countdownInterval;

    // Check URL URLSearchParams to pre-fill email and automatically transition to OTP
    const params = new URLSearchParams(window.location.search);
    const prefillEmail = params.get('email');
    if (prefillEmail) {
        activeEmail = prefillEmail;
        emailInput.value = prefillEmail;
        transitionToVerify();
        showAlert('We have dispatched an email containing your authentication pin.', false);
    }

    function showAlert(msg, isError) {
        alertBox.textContent = msg;
        alertBox.className = `rounded-md p-3 mb-4 text-sm font-medium ${isError ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200'}`;
        alertBox.classList.remove('hidden');
    }

    function hideAlert() {
        alertBox.classList.add('hidden');
    }

    function startTimer() {
        clearInterval(countdownInterval);
        let time = 300; // 5 minutes
        btnResend.disabled = true;
        btnResend.classList.replace('text-blue-600', 'text-gray-400');
        
        countdownInterval = setInterval(() => {
            time--;
            let mins = Math.floor(time / 60).toString().padStart(2, '0');
            let secs = (time % 60).toString().padStart(2, '0');
            timerSpan.textContent = `(${mins}:${secs})`;
            if (time <= 0) {
                clearInterval(countdownInterval);
                timerSpan.textContent = '';
                btnResend.disabled = false;
                btnResend.classList.replace('text-gray-400', 'text-blue-600');
            }
        }, 1000);
    }

    function transitionToVerify() {
        requestOtpForm.classList.add('hidden');
        verifyOtpForm.classList.remove('hidden');
        formSubtitle.innerHTML = `We sent a 6-digit code to <span class="font-bold text-gray-900">${activeEmail}</span>`;
        startTimer();
        setTimeout(() => otpInputs[0].focus(), 100);
    }

    function transitionToRequest() {
        verifyOtpForm.classList.add('hidden');
        requestOtpForm.classList.remove('hidden');
        formSubtitle.textContent = 'Access your DriveGuard dashboard using a standard One-Time Password.';
        hideAlert();
        clearInterval(countdownInterval);
    }

    // OTP Input Matrix logic
    otpInputs.forEach((input, index) => {
        // Prevent non-numeric
        input.addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (this.value !== '') {
                if (index < otpInputs.length - 1) otpInputs[index + 1].focus();
            }
            updateHiddenOtp();
        });
        // Handle Backspace traversal
        input.addEventListener('keydown', function(e) {
            if (e.key === 'Backspace' && this.value === '') {
                if (index > 0) otpInputs[index - 1].focus();
            }
        });
        // Handle Paste bulk input
        input.addEventListener('paste', function(e) {
            e.preventDefault();
            const pastedData = e.clipboardData.getData('text').replace(/[^0-9]/g, '').slice(0, 6);
            if (pastedData) {
                for (let i = 0; i < pastedData.length; i++) {
                    otpInputs[i].value = pastedData[i];
                }
                otpInputs[Math.min(pastedData.length, 5)].focus();
                updateHiddenOtp();
            }
        });
    });

    function updateHiddenOtp() {
        let code = '';
        otpInputs.forEach(input => code += input.value);
        fullOtpCode.value = code;
        
        // Auto-submit if completely filled
        if (code.length === 6) {
            btnVerifyOtp.click();
        }
    }

    async function dispatchOtp() {
        hideAlert();
        btnRequestOtp.disabled = true;
        btnResend.disabled = true;
        
        const otText = btnRequestOtp.innerHTML;
        btnRequestOtp.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Sending...';
        
        try {
            const res = await fetch('/api/user/send-otp', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: activeEmail })
            });
            const data = await res.json();
            
            if (res.ok && data.success) {
                transitionToVerify();
                showAlert('A new verification code has been dispatched to your email.', false);
            } else {
                showAlert(data.message || 'Failed to dispatch email.', true);
            }
        } catch (e) {
            showAlert('Network configuration error.', true);
        } finally {
            btnRequestOtp.disabled = false;
            btnRequestOtp.innerHTML = otText;
        }
    }

    requestOtpForm.addEventListener('submit', (e) => {
        e.preventDefault();
        activeEmail = emailInput.value.trim();
        dispatchOtp();
    });

    btnResend.addEventListener('click', (e) => {
        e.preventDefault();
        dispatchOtp();
    });

    btnChangeEmail.addEventListener('click', (e) => {
        e.preventDefault();
        // Erase values
        otpInputs.forEach(i => i.value = '');
        fullOtpCode.value = '';
        transitionToRequest();
    });

    verifyOtpForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const finalOtp = fullOtpCode.value;
        if (finalOtp.length < 6) return showAlert('Please enter all 6 digits.', true);

        hideAlert();
        btnVerifyOtp.disabled = true;
        const otText = btnVerifyOtp.innerHTML;
        btnVerifyOtp.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Verifying...';

        try {
            const res = await fetch('/api/user/verify-otp', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: activeEmail, otp: finalOtp })
            });
            const data = await res.json();
            
            if (res.ok && data.success) {
                btnVerifyOtp.className = "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-extrabold text-white bg-emerald-600 transition-all duration-200";
                btnVerifyOtp.innerHTML = '<i class="fas fa-check-circle mr-2"></i> Verified!';
                setTimeout(() => window.location.href = data.redirect, 800);
            } else {
                showAlert(data.message || 'Invalid or expired code.', true);
                // Shake animation for failure contextually
                document.getElementById('otpContainer').classList.add('animate-bounce');
                setTimeout(() => document.getElementById('otpContainer').classList.remove('animate-bounce'), 500);
            }
        } catch (e) {
            showAlert('Network error while validating code.', true);
        } finally {
            btnVerifyOtp.disabled = false;
            if(!btnVerifyOtp.innerHTML.includes('Verified')) { btnVerifyOtp.innerHTML = otText; }
            otpInputs.forEach(i => i.value = '');
            otpInputs[0].focus();
        }
    });

});
</script>

<%- include('partials/footer') %>
